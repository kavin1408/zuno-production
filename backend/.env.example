# OpenRouter AI API Key (Required for AI mentor functionality)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Database Configuration (Supabase PostgreSQL)
DATABASE_URL=postgresql://user:password@host:port/database

# JWT Secret for Authentication
JWT_SECRET=your_jwt_secret_key_here

# CORS Configuration (Optional - defaults to allowing all origins in development)
ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend-domain.vercel.app
